# ─── Server ───────────────────────────────────────────
NODE_ENV=development
PORT=3000
HOST=0.0.0.0
LOG_LEVEL=info

# ─── Database ─────────────────────────────────────────
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/shipping_estimator?schema=public"

# ─── Redis ────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ─── Cache TTL (seconds) ─────────────────────────────
CACHE_TTL_NEAREST_WAREHOUSE=300
CACHE_TTL_SHIPPING_CHARGE=60
